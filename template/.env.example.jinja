APP_NAME={{ project_name }}
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=false

# 日志配置
# 当 LOG_FORMAT=auto 时，生产环境输出 JSON，其他环境输出彩色文本。
LOG_LEVEL=INFO
LOG_FORMAT=auto
LOG_ENQUEUE=true
LOG_FILE_ENABLED=false
LOG_FILE_DIR=logs
LOG_FILE_ROTATION=100 MB
LOG_FILE_RETENTION=30 days
LOG_FILE_COMPRESSION=gz

API_V1_PREFIX=/api/v1
SERVER_HOST=0.0.0.0
SERVER_PORT={{ server_port }}
SERVER_RELOAD=false

DATABASE_URL=sqlite:///./app.db
CORS_ORIGINS=["http://localhost:3000"]

# HTTP 中间件
GZIP_ENABLED=true
GZIP_MIN_SIZE=1000
GZIP_COMPRESS_LEVEL=6
TRUSTED_HOSTS=["*"]
