APP_NAME={{ project_name }}
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=false

# 日志配置
# 当 LOG_FORMAT=auto 时，生产环境输出 JSON，其他环境输出彩色文本。
LOG_LEVEL=INFO
LOG_FORMAT=auto
LOG_ENQUEUE=true
LOG_FILE_ENABLED=false
LOG_FILE_DIR=logs
LOG_FILE_ROTATION=100 MB
LOG_FILE_RETENTION=30 days
LOG_FILE_COMPRESSION=gz

API_V1_PREFIX=/api/v1
DOCS_ENABLED=true
SERVER_HOST=0.0.0.0
SERVER_PORT={{ server_port }}
SERVER_RELOAD=false

# 默认使用 SQLite，PostgreSQL/MySQL 可直接替换连接串。
# PostgreSQL 示例：postgresql://user:password@localhost:5432/app
# MySQL 示例：mysql://user:password@localhost:3306/app?charset=utf8mb4
DATABASE_URL=sqlite:///./app.db
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_READY_TIMEOUT=5.0
CORS_ORIGINS=["http://localhost:3000"]

# HTTP 中间件
GZIP_ENABLED=true
GZIP_MIN_SIZE=1000
GZIP_COMPRESS_LEVEL=6
TRUSTED_HOSTS=["*"]
