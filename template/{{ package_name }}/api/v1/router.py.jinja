from fastapi import APIRouter, status

from {{ package_name }}.api.v1.examples.router import router as examples_router
from {{ package_name }}.core.config import settings
from {{ package_name }}.core.responses import ErrorResponse


def build_api_router() -> APIRouter:
    """构建 v1 聚合路由，仅在 DEBUG 模式下挂载示例接口。"""
    api_router = APIRouter(
        responses={
            status.HTTP_422_UNPROCESSABLE_CONTENT: {
                "model": ErrorResponse,
                "description": (
                    "请求参数校验失败，响应体遵循统一错误结构。"
                ),
            },
            status.HTTP_500_INTERNAL_SERVER_ERROR: {
                "model": ErrorResponse,
                "description": (
                    "服务内部异常，响应体遵循统一错误结构。"
                ),
            },
        },
    )
    if settings.DEBUG:
        # 示例接口仅用于联调，DEBUG 关闭时不进入生产路由。
        api_router.include_router(examples_router)
    return api_router
