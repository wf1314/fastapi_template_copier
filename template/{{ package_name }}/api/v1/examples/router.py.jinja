from fastapi import APIRouter, status

from {{ package_name }}.api.v1.examples.schema import (
    ExampleErrorRequest,
    ExampleSuccessData,
    ExampleSuccessRequest,
    ExampleSuccessResponse,
)
from {{ package_name }}.core.exceptions import AppException
from {{ package_name }}.core.responses import (
    ApiResponse,
    ErrorResponse,
    success_response,
)

router = APIRouter(prefix="/examples", tags=["示例接口"])


@router.post(
    "/success",
    status_code=status.HTTP_200_OK,
    response_model=ExampleSuccessResponse,
    response_description="示例请求已被接受。",
    operation_id="create_example_success",
    summary="成功响应示例",
    description=(
        "接收示例任务请求并返回统一成功响应，"
        "便于查看请求体、响应体和字段说明。"
    ),
)
async def example_success(
    payload: ExampleSuccessRequest,
) -> ApiResponse[ExampleSuccessData]:
    """返回统一成功响应的示例接口。"""
    return success_response(
        ExampleSuccessData(
            request_id=f"example-{payload.name}-{payload.priority}",
            message="Example request accepted",
            accepted=True,
            echo=payload,
        )
    )


@router.post(
    "/error",
    status_code=status.HTTP_400_BAD_REQUEST,
    response_model=ErrorResponse,
    response_description="示例业务错误响应。",
    operation_id="create_example_error",
    summary="错误响应示例",
    description=(
        "接收示例错误请求并抛出业务异常，"
        "展示统一错误响应结构。"
    ),
)
async def example_error(
    payload: ExampleErrorRequest,
) -> None:
    """返回统一错误响应的示例接口。"""
    raise AppException(
        "Example error",
        status_code=status.HTTP_400_BAD_REQUEST,
        code=400,
        errors=[
            {
                "field": "resource_id",
                "message": (
                    f"Resource {payload.resource_id} "
                    f"cannot be processed: {payload.reason}"
                ),
            }
        ],
    )
