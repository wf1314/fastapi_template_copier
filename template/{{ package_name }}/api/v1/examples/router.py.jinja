from fastapi import APIRouter, Query, status

from {{ package_name }}.api.v1.examples.schema import (
    ExampleErrorRequest,
    ExampleItemData,
    ExampleListResponse,
    ExampleSuccessData,
    ExampleSuccessRequest,
    ExampleSuccessResponse,
)
from {{ package_name }}.core.exception.error_codes import ErrorCode
from {{ package_name }}.core.exception.exceptions import AppException
from {{ package_name }}.core.responses import (
    ApiResponse,
    ErrorItem,
    ErrorResponse,
    PaginatedData,
    paginated_response,
    success_response,
)

router = APIRouter(prefix="/examples", tags=["示例接口"])


EXAMPLE_ITEMS = [
    ExampleItemData(id="item-1", name="Example item 1", priority=1),
    ExampleItemData(id="item-2", name="Example item 2", priority=2),
    ExampleItemData(id="item-3", name="Example item 3", priority=3),
    ExampleItemData(id="item-4", name="Example item 4", priority=4),
    ExampleItemData(id="item-5", name="Example item 5", priority=5),
]


@router.post(
    "/success",
    status_code=status.HTTP_200_OK,
    response_model=ExampleSuccessResponse,
    response_description="示例请求已被接受。",
    operation_id="create_example_success",
    summary="成功响应示例",
    description=(
        "接收示例任务请求并返回统一成功响应，"
        "便于查看请求体、响应体和字段说明。"
    ),
)
async def example_success(
    payload: ExampleSuccessRequest,
) -> ApiResponse[ExampleSuccessData]:
    """返回统一成功响应的示例接口。"""
    return success_response(
        ExampleSuccessData(
            request_id=f"example-{payload.name}-{payload.priority}",
            message="Example request accepted",
            accepted=True,
            echo=payload,
        )
    )


@router.get(
    "/items",
    status_code=status.HTTP_200_OK,
    response_model=ExampleListResponse,
    response_description="示例分页列表已返回。",
    operation_id="list_example_items",
    summary="分页列表响应示例",
    description=(
        "返回统一分页列表响应，展示 items 和 pagination "
        "在统一响应 data 字段中的组织方式。"
    ),
)
async def list_example_items(
    page: int = Query(default=1, ge=1, description="页码，从 1 开始。"),
    page_size: int = Query(default=2, ge=1, le=100, description="每页数量。"),
) -> ApiResponse[PaginatedData[ExampleItemData]]:
    """返回统一分页列表响应的示例接口。"""
    start = (page - 1) * page_size
    end = start + page_size
    return paginated_response(
        EXAMPLE_ITEMS[start:end],
        page=page,
        page_size=page_size,
        total=len(EXAMPLE_ITEMS),
    )


@router.post(
    "/error",
    status_code=status.HTTP_400_BAD_REQUEST,
    response_model=ErrorResponse,
    response_description="示例业务错误响应。",
    operation_id="create_example_error",
    summary="错误响应示例",
    description=(
        "接收示例错误请求并抛出业务异常，"
        "展示统一错误响应结构。"
    ),
)
async def example_error(
    payload: ExampleErrorRequest,
) -> None:
    """返回统一错误响应的示例接口。"""
    raise AppException(
        "Example error",
        status_code=status.HTTP_400_BAD_REQUEST,
        code=ErrorCode.BAD_REQUEST,
        errors=[
            ErrorItem(
                field="resource_id",
                message=(
                    f"Resource {payload.resource_id} "
                    f"cannot be processed: {payload.reason}"
                ),
                code="invalid_resource_state",
            )
        ],
    )
