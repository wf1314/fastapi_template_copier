from typing import Any

from pydantic import BaseModel, ConfigDict, Field

__all__ = [
    "ApiResponse",
    "ErrorItem",
    "ErrorResponse",
    "PaginatedData",
    "PaginationMeta",
    "error_response_content",
    "paginated_response",
    "success_response",
]


class ErrorItem(BaseModel):
    """统一错误明细项。"""

    model_config = ConfigDict(extra="allow")

    field: str | None = Field(
        default=None,
        description="出错字段或业务对象标识；无法定位到字段时为 null。",
        examples=["resource_id"],
    )
    message: str = Field(
        description="面向调用方的错误明细消息。",
        examples=["Resource cannot be processed."],
    )
    code: str | None = Field(
        default=None,
        description="错误明细码，可用于前端按字段或规则做精确处理。",
        examples=["invalid_resource_state"],
    )


class PaginationMeta(BaseModel):
    """分页元信息。"""

    page: int = Field(ge=1, description="当前页码，从 1 开始。", examples=[1])
    page_size: int = Field(ge=1, description="每页数量。", examples=[20])
    total: int = Field(ge=0, description="总记录数。", examples=[42])
    total_pages: int = Field(ge=0, description="总页数。", examples=[3])


class PaginatedData[ItemT](BaseModel):
    """统一分页列表数据结构。"""

    items: list[ItemT] = Field(description="当前页数据列表。")
    pagination: PaginationMeta = Field(description="分页元信息。")


class ApiResponse[DataT](BaseModel):
    """所有接口共用的响应包裹结构。"""

    code: int = Field(description="业务状态码，0 表示成功。", examples=[0])
    message: str = Field(description="响应消息。", examples=["success"])
    data: DataT | None = Field(default=None, description="业务响应数据。")
    errors: list[ErrorItem] | None = Field(
        default=None,
        description="结构化错误明细；成功响应为 null。",
    )


class ErrorResponse(BaseModel):
    """统一错误响应结构，用于 Swagger 展示通用异常格式。"""

    code: int = Field(
        description="业务错误码；0 表示成功，100xxx 为模板内置通用错误码。",
        examples=[
            100400,
            100422,
            100500,
        ],
    )
    message: str = Field(
        description="错误消息。",
        examples=[
            "Example error",
            "Request validation failed",
            "Internal server error",
        ],
    )
    data: None = Field(default=None, description="错误响应没有业务数据。")
    errors: list[ErrorItem] | None = Field(
        default=None,
        description="结构化错误明细；没有明细时为 null。",
    )


def success_response[DataT](
    data: DataT | None = None,
    *,
    message: str = "success",
    code: int = 0,
) -> ApiResponse[DataT]:
    """构造统一成功响应。"""
    return ApiResponse(code=int(code), message=message, data=data, errors=None)


def paginated_response[ItemT](
    items: list[ItemT],
    *,
    page: int,
    page_size: int,
    total: int,
    message: str = "success",
    code: int = 0,
) -> ApiResponse[PaginatedData[ItemT]]:
    """构造统一分页列表响应。"""
    if page < 1:
        raise ValueError("page must be greater than or equal to 1")
    if page_size < 1:
        raise ValueError("page_size must be greater than or equal to 1")
    if total < 0:
        raise ValueError("total must be greater than or equal to 0")

    total_pages = (total + page_size - 1) // page_size
    return success_response(
        PaginatedData(
            items=items,
            pagination=PaginationMeta(
                page=page,
                page_size=page_size,
                total=total,
                total_pages=total_pages,
            ),
        ),
        message=message,
        code=code,
    )


def error_response_content(
    *,
    code: int,
    message: str,
    errors: list[ErrorItem] | None = None,
    data: Any | None = None,
) -> dict[str, Any]:
    """构造统一错误响应内容，供异常处理器直接序列化。"""
    return {
        "code": int(code),
        "message": message,
        "data": data,
        "errors": errors,
    }
