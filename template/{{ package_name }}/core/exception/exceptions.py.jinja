from fastapi import status

from {{ package_name }}.core.error_items import ErrorItem
from {{ package_name }}.core.exception.error_codes import ErrorCode, default_error_code


class AppException(Exception):
    """业务异常。

    携带统一响应所需的状态码、业务码和错误明细。
    """

    def __init__(
        self,
        message: str,
        *,
        status_code: int = status.HTTP_400_BAD_REQUEST,
        code: int | ErrorCode | None = None,
        errors: list[ErrorItem] | None = None,
    ) -> None:
        self.message = message
        self.status_code = status_code
        self.code = int(code if code is not None else default_error_code(status_code))
        self.errors = errors
        super().__init__(message)
