import httpx
import pytest
from fastapi import HTTPException

from {{ package_name }}.core.config import settings
from {{ package_name }}.core.exceptions import AppException
from {{ package_name }}.main import create_app


@pytest.mark.asyncio
async def test_app_exception_uses_unified_response() -> None:
    app = create_app()

    @app.get("/raises-app-exception")
    async def raises_app_exception() -> None:
        raise AppException(
            "Invalid operation",
            status_code=409,
            code=10001,
            errors=[{"field": "state", "message": "already processed"}],
        )

    transport = httpx.ASGITransport(app=app)
    async with httpx.AsyncClient(
        transport=transport,
        base_url="http://test",
    ) as client:
        response = await client.get("/raises-app-exception")

    assert response.status_code == 409
    assert response.json() == {
        "code": 10001,
        "message": "Invalid operation",
        "data": None,
        "errors": [{"field": "state", "message": "already processed"}],
    }


