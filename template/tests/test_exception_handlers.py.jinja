@pytest.mark.asyncio
async def test_validation_exception_uses_unified_response(
    async_client_for_app: AsyncClientFactory,
) -> None:
    app = create_app()

    @app.get("/items")
    async def list_items(limit: int) -> dict[str, int]:
        return {"limit": limit}

    async with async_client_for_app(app, "http://test", True) as client:
        response = await client.get("/items", params={"limit": "invalid"})

    payload = response.json()
    assert response.status_code == 422
    assert payload["code"] == int(ErrorCode.VALIDATION_ERROR)
    assert payload["message"] == "Request validation failed"
    assert payload["data"] is None
    assert isinstance(payload["errors"], list)
    assert payload["errors"][0]["field"] == "query.limit"
    assert payload["errors"][0]["code"] == "int_parsing"


@pytest.mark.asyncio
async def test_unhandled_exception_hides_message_by_default(
    async_client_for_app: AsyncClientFactory,
) -> None:
    app = create_app()

    @app.get("/raises-unhandled-exception")
    async def raises_unhandled_exception() -> None:
        raise RuntimeError("database password leaked")

    async with async_client_for_app(app, "http://test", False) as client:
        response = await client.get("/raises-unhandled-exception")

    assert response.status_code == 500
    assert response.json() == {
        "code": int(ErrorCode.INTERNAL_ERROR),
        "message": "Internal server error",
        "data": None,
        "errors": None,
    }


@pytest.mark.asyncio
async def test_unhandled_exception_shows_message_in_debug(
    async_client_for_app: AsyncClientFactory,
) -> None:
    original_debug = settings.DEBUG
    settings.DEBUG = True
    try:
        app = create_app()

        @app.get("/raises-debug-exception")
        async def raises_debug_exception() -> None:
            raise RuntimeError("debug failure")

        async with async_client_for_app(app, "http://test", False) as client:
            response = await client.get("/raises-debug-exception")
    finally:
        settings.DEBUG = original_debug

    assert response.status_code == 500
    assert response.json() == {
        "code": int(ErrorCode.INTERNAL_ERROR),
        "message": "debug failure",
        "data": None,
        "errors": None,
    }


@pytest.mark.asyncio
async def test_unhandled_exception_log_includes_request_context(
    async_client_for_app: AsyncClientFactory,
    json_request_logging: None,
    capsys: CaptureFixture[str],
) -> None:
    app = create_app()

    @app.get("/raises-context-exception")
    async def raises_context_exception() -> None:
        raise RuntimeError("context failure")

    async with async_client_for_app(app, "http://test", False) as client:
        response = await client.get(
            "/raises-context-exception",
            headers={
                REQUEST_ID_HEADER: "request-error-1",
                TRACE_ID_HEADER: "trace-error-1",
            },
        )

    assert response.status_code == 500
    assert response.headers[REQUEST_ID_HEADER] == "request-error-1"
    assert response.headers[TRACE_ID_HEADER] == "trace-error-1"
    records = [
        json.loads(line)["record"]
        for line in capsys.readouterr().err.splitlines()
        if "Unhandled exception" in line
    ]

    assert len(records) == 1
    record = records[0]
    assert record["message"] == "Unhandled exception"
    assert record["extra"]["request_id"] == "request-error-1"
    assert record["extra"]["trace_id"] == "trace-error-1"
    assert record["extra"]["method"] == "GET"
    assert record["extra"]["path"] == "/raises-context-exception"
    assert record["extra"]["status_code"] == 500
