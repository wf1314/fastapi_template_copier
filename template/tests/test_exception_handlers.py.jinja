@pytest.mark.asyncio
async def test_validation_exception_uses_unified_response() -> None:
    app = create_app()

    @app.get("/items")
    async def list_items(limit: int) -> dict[str, int]:
        return {"limit": limit}

    transport = httpx.ASGITransport(app=app)
    async with httpx.AsyncClient(
        transport=transport,
        base_url="http://test",
    ) as client:
        response = await client.get("/items", params={"limit": "invalid"})

    payload = response.json()
    assert response.status_code == 422
    assert payload["code"] == 422
    assert payload["message"] == "Request validation failed"
    assert payload["data"] is None
    assert isinstance(payload["errors"], list)
    assert payload["errors"][0]["loc"] == ["query", "limit"]


@pytest.mark.asyncio
async def test_unhandled_exception_hides_message_by_default() -> None:
    app = create_app()

    @app.get("/raises-unhandled-exception")
    async def raises_unhandled_exception() -> None:
        raise RuntimeError("database password leaked")

    transport = httpx.ASGITransport(app=app, raise_app_exceptions=False)
    async with httpx.AsyncClient(
        transport=transport,
        base_url="http://test",
    ) as client:
        response = await client.get("/raises-unhandled-exception")

    assert response.status_code == 500
    assert response.json() == {
        "code": 500,
        "message": "Internal server error",
        "data": None,
        "errors": None,
    }


@pytest.mark.asyncio
async def test_unhandled_exception_shows_message_in_debug() -> None:
    original_debug = settings.DEBUG
    settings.DEBUG = True
    try:
        app = create_app()

        @app.get("/raises-debug-exception")
        async def raises_debug_exception() -> None:
            raise RuntimeError("debug failure")

        transport = httpx.ASGITransport(app=app, raise_app_exceptions=False)
        async with httpx.AsyncClient(
            transport=transport,
            base_url="http://test",
        ) as client:
            response = await client.get("/raises-debug-exception")
    finally:
        settings.DEBUG = original_debug

    assert response.status_code == 500
    assert response.json() == {
        "code": 500,
        "message": "debug failure",
        "data": None,
        "errors": None,
    }
