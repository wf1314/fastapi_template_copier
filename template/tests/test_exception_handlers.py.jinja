@pytest.mark.asyncio
async def test_app_exception_uses_unified_response(
    async_client_for_app: AsyncClientFactory,
) -> None:
    app = create_app()

    @app.get("/raises-app-exception")
    async def raises_app_exception() -> None:
        raise AppException(
            "Invalid operation",
            status_code=409,
            code=10001,
            errors=[
                ErrorItem(
                    field="state",
                    message="already processed",
                    code="invalid_state",
                )
            ],
        )

    async with async_client_for_app(app, "http://test", True) as client:
        response = await client.get("/raises-app-exception")

    assert response.status_code == 409
    assert response.json() == {
        "code": 10001,
        "message": "Invalid operation",
        "data": None,
        "errors": [
            {
                "field": "state",
                "message": "already processed",
                "code": "invalid_state",
            }
        ],
    }


