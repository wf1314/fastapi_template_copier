import pytest
from pytest import MonkeyPatch

from {{ package_name }} import main as app_main


@pytest.mark.asyncio
async def test_lifespan_disposes_database_engine(monkeypatch: MonkeyPatch) -> None:
    disposed = False

    async def fake_dispose_engine() -> None:
        nonlocal disposed
        disposed = True

    monkeypatch.setattr(app_main, "dispose_engine", fake_dispose_engine)

    async with app_main.lifespan(app_main.create_app()):
        assert not disposed

    assert disposed
