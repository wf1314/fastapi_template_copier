@pytest.fixture
def middleware_settings() -> Iterator[None]:
    original_values = {
        "GZIP_ENABLED": settings.GZIP_ENABLED,
        "GZIP_MIN_SIZE": settings.GZIP_MIN_SIZE,
        "GZIP_COMPRESS_LEVEL": settings.GZIP_COMPRESS_LEVEL,
        "TRUSTED_HOSTS": settings.TRUSTED_HOSTS,
    }
    try:
        yield
    finally:
