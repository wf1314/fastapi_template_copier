from collections.abc import AsyncIterator, Callable
from contextlib import AbstractAsyncContextManager, asynccontextmanager

import httpx
import pytest
from fastapi import FastAPI
from sqlalchemy.ext.asyncio import async_sessionmaker, create_async_engine

from {{ package_name }}.core.config import settings
from {{ package_name }}.db import session as db_session
from {{ package_name }}.main import create_app

TEST_DATABASE_URL = "sqlite:///:memory:"

type AsyncClientContext = AbstractAsyncContextManager[httpx.AsyncClient]
type AsyncClientFactory = Callable[
    [FastAPI | None, str, bool],
    AsyncClientContext,
]


@pytest.fixture(autouse=True)
async def test_database_url() -> AsyncIterator[None]:
    """测试默认使用独立内存 SQLite，避免误连本地或共享数据库。"""
    original_database_url = settings.DATABASE_URL
    original_engine = db_session.engine
    original_session_maker = db_session.async_session_maker

    settings.DATABASE_URL = TEST_DATABASE_URL
    test_engine = create_async_engine(
        settings.async_database_url,
        echo=settings.DEBUG,
    )
    db_session.engine = test_engine
    db_session.async_session_maker = async_sessionmaker(
        test_engine,
        expire_on_commit=False,
        autoflush=False,
    )
    try:
        yield
    finally:
        await test_engine.dispose()
        settings.DATABASE_URL = original_database_url
        db_session.engine = original_engine
        db_session.async_session_maker = original_session_maker


@pytest.fixture
def async_client_for_app() -> AsyncClientFactory:
    """为指定 ASGI app 创建测试客户端。"""

    @asynccontextmanager
    async def client_for_app(
        app: FastAPI | None = None,
        base_url: str = "http://test",
        raise_app_exceptions: bool = True,
    ) -> AsyncIterator[httpx.AsyncClient]:
        transport = httpx.ASGITransport(
            app=app or create_app(),
            raise_app_exceptions=raise_app_exceptions,
        )
        async with httpx.AsyncClient(
            transport=transport,
            base_url=base_url,
        ) as client:
            yield client

    return client_for_app


@pytest.fixture
async def async_client(
    async_client_for_app: AsyncClientFactory,
